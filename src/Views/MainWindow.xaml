<Window x:Class="ImagePromptStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ImagePromptStudio"
        Title="{Binding WindowTitle}"
        Width="1480"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        Background="#101216"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DrawingBrush x:Key="CheckerBrush"
                      TileMode="Tile"
                      Viewport="0,0,24,24"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#22262d">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,24,24" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#2d323a">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,12,12" />
                                <RectangleGeometry Rect="12,12,12,12" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e8edf4" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#b8c1cc" />
            <Setter Property="Padding" Value="0,0,0,5" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#161a20" />
            <Setter Property="Foreground" Value="#edf3fb" />
            <Setter Property="CaretBrush" Value="#edf3fb" />
            <Setter Property="BorderBrush" Value="#303844" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="CompactButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="8,2" />
        </Style>
        <Style x:Key="CompactComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#151922" />
            <Setter Property="BorderBrush" Value="#27303b" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <TextBlock Text="Project"
                           VerticalAlignment="Center"
                           Foreground="#8f9baa"
                           Margin="0,0,8,0" />
                <ComboBox x:Name="ProjectCombo"
                           Width="180"
                          Style="{StaticResource CompactComboBox}"
                          Margin="0,0,8,0"
                          DisplayMemberPath="Name"
                          SelectionChanged="ProjectCombo_SelectionChanged" />
                <Button x:Name="NewProjectButton"
                        Content="New"
                        Width="72"
                        Style="{StaticResource CompactButton}"
                        Margin="0,0,8,0"
                        Click="NewProject_Click" />
                <Button Content="Open"
                        Width="72"
                        Style="{StaticResource CompactButton}"
                        Margin="0,0,8,0"
                        Click="OpenProjectFolder_Click" />
                <Button Content="Remove"
                        Width="78"
                        Style="{StaticResource CompactButton}"
                        Click="RemoveProject_Click" />
                <Border Background="#111820"
                        BorderBrush="#2b3542"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,3"
                        Margin="12,0,0,0"
                        MinHeight="26"
                        Visibility="{Binding IsOpenAiBudgetVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTip="{Binding OpenAiBudgetToolTip}">
                    <TextBlock Text="{Binding OpenAiBudgetText}"
                               VerticalAlignment="Center"
                               Foreground="#b7d7ff"
                               FontSize="12" />
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="395" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="430" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="Prompt" />
                            <Grid>
                                <TextBox x:Name="PromptBox"
                                         MinHeight="32"
                                         MaxHeight="155"
                                         VerticalScrollBarVisibility="Disabled"
                                         TextChanged="AutoGrowTextBox_TextChanged" />
                                <TextBlock Text="Describe the image you want to generate. Ctrl+Enter to run."
                                           Foreground="#5b6675"
                                           Margin="10,7,10,0"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Top">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=PromptBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Label Content="Constraints" Margin="0,12,0,0" />
                            <Grid>
                                <TextBox x:Name="ConstraintsBox"
                                         MinHeight="32"
                                         MaxHeight="120"
                                         VerticalScrollBarVisibility="Disabled"
                                         TextChanged="AutoGrowTextBox_TextChanged" />
                                <TextBlock Text="Required elements, style cues, or constraints."
                                           Foreground="#5b6675"
                                           Margin="10,7,10,0"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Top">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=ConstraintsBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Label Content="Negative" Margin="0,12,0,0" />
                            <Grid>
                                <TextBox x:Name="NegativeBox"
                                         MinHeight="32"
                                         MaxHeight="120"
                                         VerticalScrollBarVisibility="Disabled"
                                         TextChanged="AutoGrowTextBox_TextChanged" />
                                <TextBlock Text="Things to avoid (e.g. text, watermarks, extra fingers)."
                                           Foreground="#5b6675"
                                           Margin="10,7,10,0"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Top">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=NegativeBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Separator Margin="0,16,0,14" Background="#2b3441" />

                            <Label Content="Model" />
                            <ComboBox x:Name="ModelCombo" SelectionChanged="ModelCombo_SelectionChanged" />

                            <Label Content="Mode" />
                            <ComboBox x:Name="ModeCombo" SelectionChanged="ModeCombo_SelectionChanged" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Label Content="Size" />
                                    <ComboBox x:Name="SizeCombo" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <Label Content="Quality" />
                                    <ComboBox x:Name="QualityCombo" />
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Label Content="Background" />
                                    <ComboBox x:Name="BackgroundCombo" SelectionChanged="BackgroundCombo_SelectionChanged" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <Label Content="Output" />
                                    <ComboBox x:Name="OutputCombo" />
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Label Content="Input fidelity" />
                                    <ComboBox x:Name="FidelityCombo" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <Label Content="Prompt augment" />
                                    <ComboBox x:Name="AugmentCombo" />
                                </StackPanel>
                            </Grid>

                            <Label Content="Reference" Margin="0,8,0,0" />
                            <TextBlock Text="{Binding ReferenceLabel}"
                                       Foreground="#9faaba"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BrowseReferenceButton"
                                        Content="Browse Reference"
                                        Click="BrowseReference_Click" />
                                <Button x:Name="ClearReferenceButton"
                                        Grid.Column="2"
                                        Content="Clear"
                                        Click="ClearReference_Click" />
                                <Button Grid.Column="4"
                                        Content="Edit Viewed"
                                        Click="EditViewed_Click"
                                        IsEnabled="{Binding CanUseSelectedImage}" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Margin="0,14,8,0">
                        <Button Content="Generate"
                                FontWeight="SemiBold"
                                Background="#3d7be0"
                                Foreground="White"
                                BorderThickness="0"
                                Click="Generate_Click" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="300" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="320" MinHeight="230" />
                    </Grid.RowDefinitions>

                            <Border x:Name="PreviewViewport"
                            Grid.Row="0"
                            Background="{StaticResource CheckerBrush}"
                            BorderBrush="#28313d"
                            BorderThickness="1"
                            CornerRadius="6"
                            ClipToBounds="True"
                            MouseWheel="PreviewViewport_MouseWheel"
                            MouseLeftButtonDown="PreviewViewport_MouseLeftButtonDown"
                            MouseLeftButtonUp="PreviewViewport_MouseLeftButtonUp"
                            MouseMove="PreviewViewport_MouseMove"
                            SizeChanged="PreviewViewport_SizeChanged">
                        <Border.ContextMenu>
                            <ContextMenu Opened="PreviewContextMenu_Opened">
                                <MenuItem x:Name="PreviewCopyImageMenuItem"
                                          Header="Copy as Image"
                                          Click="CopyAsImage_Click" />
                                <MenuItem x:Name="PreviewCopyFileMenuItem"
                                          Header="Copy as File"
                                          Click="CopyAsFile_Click" />
                                <MenuItem x:Name="PreviewSaveAsMenuItem"
                                          Header="Save As..."
                                          Click="SaveAs_Click" />
                                <Separator />
                                <MenuItem x:Name="PreviewShowInExplorerMenuItem"
                                          Header="Show in Explorer"
                                          Click="ShowInExplorer_Click" />
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                            <Image x:Name="PreviewImageControl"
                                   Source="{Binding PreviewImage}"
                                   Stretch="Uniform"
                                   Margin="14"
                                   RenderTransformOrigin="0.5,0.5"
                                   SnapsToDevicePixels="True">
                                <Image.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="{Binding PreviewZoom}" ScaleY="{Binding PreviewZoom}" />
                                        <TranslateTransform X="{Binding PreviewOffsetX}" Y="{Binding PreviewOffsetY}" />
                                    </TransformGroup>
                                </Image.RenderTransform>
                            </Image>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsPreviewMessageVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding PreviewMessage}"
                                           Foreground="#aeb8c7"
                                           FontSize="17"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="500" />
                                <ProgressBar Width="240"
                                            Height="6"
                                             Margin="0,18,0,0"
                                             IsIndeterminate="True"
                                             Visibility="{Binding IsSelectedInProgress, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="1"
                                  Height="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="#27303b"
                                  ShowsPreview="True" />

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#111820"
                                BorderBrush="#26303b"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Preview background"
                                               Foreground="#8f9baa"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <ComboBox x:Name="PreviewBackgroundCombo"
                                              Width="145"
                                              Style="{StaticResource CompactComboBox}"
                                              SelectionChanged="PreviewBackgroundCombo_SelectionChanged" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="Copy as File"
                                        Width="104"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource CompactButton}"
                                        Click="CopyAsFile_Click"
                                        IsEnabled="{Binding CanUseSelectedImage}" />
                                <Button Grid.Column="3"
                                        Content="Copy as Image"
                                        Width="112"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource CompactButton}"
                                        Click="CopyAsImage_Click"
                                        IsEnabled="{Binding CanUseSelectedImage}" />
                                <Button Grid.Column="4"
                                        Content="Save As..."
                                        Width="82"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource CompactButton}"
                                        Click="SaveAs_Click"
                                        IsEnabled="{Binding CanUseSelectedImage}" />
                                <Button Grid.Column="5"
                                        Content="Fit"
                                        Width="54"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource CompactButton}"
                                        Click="ResetPreview_Click"
                                        IsEnabled="{Binding HasPreviewImage}" />
                            </Grid>
                        </Border>

                    <Border Grid.Row="1" Background="#11151c" BorderBrush="#26303b" BorderThickness="1" CornerRadius="6" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.ColumnSpan="2" Margin="0,0,0,10" LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Viewed Item"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="Reuse"
                                            Width="78"
                                            Style="{StaticResource CompactButton}"
                                            Click="ApplyViewed_Click"
                                            IsEnabled="{Binding CanApplySelectedEntry}" />
                                    <Button Content="Regenerate"
                                            Width="90"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource CompactButton}"
                                            ToolTip="Re-run this exact prompt and settings (F5)"
                                            Click="Regenerate_Click"
                                            IsEnabled="{Binding CanApplySelectedEntry}" />
                                    <Button Content="Edit Image"
                                            Width="90"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource CompactButton}"
                                            Click="EditViewed_Click"
                                            IsEnabled="{Binding CanUseSelectedImage}" />
                                </StackPanel>
                            </DockPanel>

                            <ScrollViewer Grid.Row="1"
                                          Grid.Column="0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          DataContext="{Binding SelectedEntry}">
                                <StackPanel>
                                    <TextBlock Text="Prompt" Foreground="#8fa1b8" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Prompt}" TextWrapping="Wrap" Margin="0,4,16,12" />
                                    <TextBlock Text="Constraints" Foreground="#8fa1b8" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Constraints}" TextWrapping="Wrap" Margin="0,4,16,12" />
                                    <TextBlock Text="Negative" Foreground="#8fa1b8" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Negative}" TextWrapping="Wrap" Margin="0,4,16,12" />
                                </StackPanel>
                            </ScrollViewer>

                            <ScrollViewer Grid.Row="1"
                                          Grid.Column="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          DataContext="{Binding SelectedEntry}">
                                <StackPanel>
                                    <TextBlock Text="{Binding StatusText}"
                                               FontWeight="SemiBold"
                                               Foreground="#b7d7ff"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding OutputFileName}"
                                               Foreground="#c7d0de"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,12" />
                                    <TextBlock Text="Settings" Foreground="#8fa1b8" FontWeight="SemiBold" />
                                     <TextBlock Text="{Binding Settings.DetailText}"
                                               TextWrapping="Wrap"
                                               Foreground="#d8e0eb"
                                               Margin="0,4,0,12" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Prompt History"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding HistorySubheading}"
                                       Foreground="#8f9baa"
                                       TextWrapping="Wrap"
                                       Margin="0,3,8,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Open Folder"
                                Width="92"
                                Style="{StaticResource CompactButton}"
                                Click="OpenFolder_Click" />
                    </Grid>

                    <ListBox x:Name="HistoryList"
                             Grid.Row="1"
                             ItemsSource="{Binding History}"
                             SelectionMode="Extended"
                             Padding="0,0,4,0"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionChanged="HistoryList_SelectionChanged"
                             PreviewMouseRightButtonDown="HistoryList_PreviewMouseRightButtonDown"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Cancel Selected" Click="CancelSelectedHistory_Click" />
                                <MenuItem Header="Delete Selected" Click="DeleteSelectedHistory_Click" />
                                <Separator />
                                <MenuItem Header="Delete All" Click="DeleteAllHistory_Click" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="SelectionFrame"
                                                    BorderThickness="2"
                                                    BorderBrush="Transparent"
                                                    CornerRadius="9"
                                                    Padding="0"
                                                    Background="Transparent">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="SelectionFrame" Property="BorderBrush" Value="#5b9dff" />
                                                    <Setter TargetName="SelectionFrame" Property="Background" Value="#1a2740" />
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="False" />
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="SelectionFrame" Property="BorderBrush" Value="#3a4659" />
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:HistoryEntry}">
                                <Border BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#10151d" />
                                            <Setter Property="BorderBrush" Value="#26303b" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="in_progress">
                                                    <Setter Property="Background" Value="#14161d" />
                                                    <Setter Property="BorderBrush" Value="#8b6b21" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="error">
                                                    <Setter Property="Background" Value="#1e1215" />
                                                    <Setter Property="BorderBrush" Value="#803434" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="canceled">
                                                    <Setter Property="Background" Value="#171920" />
                                                    <Setter Property="BorderBrush" Value="#536071" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMissingFile}" Value="True">
                                                    <Setter Property="Background" Value="#1c1710" />
                                                    <Setter Property="BorderBrush" Value="#a06f2b" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="48"
                                                Height="48"
                                                Background="#171d25"
                                                BorderBrush="#303a47"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                            <Grid ClipToBounds="True">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="UniformToFill" />
                                                <ProgressBar IsIndeterminate="True"
                                                             Width="32"
                                                             Height="6"
                                                             VerticalAlignment="Center"
                                                             HorizontalAlignment="Center"
                                                             Visibility="{Binding IsInProgress, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <TextBlock Text="{Binding StatusText}"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Foreground="#8fa1b8"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Margin="4">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding HasThumbnail}" Value="False">
                                                                     <Setter Property="Visibility" Value="Visible" />
                                                                 </DataTrigger>
                                                                 <DataTrigger Binding="{Binding IsInProgress}" Value="True">
                                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Column="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding PromptPreview}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="#edf3fb"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding MetaLinePrimary}"
                                                       Foreground="#96a4b5"
                                                       FontSize="12"
                                                       Margin="0,5,0,0"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding MetaLineSecondary}"
                                                       Foreground="#96a4b5"
                                                       FontSize="12"
                                                       Margin="0,2,0,0"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding FooterStatus}"
                   Foreground="#94a2b4"
                   Margin="2,10,0,0" />
    </Grid>
</Window>
